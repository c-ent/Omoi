# Copy to .env and fill in real values.
# No spaces around keys or = (GOOGLE_ID=value, not GOOGLE_ID = value).

MONGODB_URI=mongodb://localhost:27017/omoi
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
